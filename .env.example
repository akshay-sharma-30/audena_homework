DATABASE_URL="file:./dev.db"
API_TOKEN="audena-demo-token"
NEXT_PUBLIC_API_TOKEN="audena-demo-token"
PROVIDER_WEBHOOK_SECRET="provider-shared-secret"
PUBLIC_BASE_URL="http://localhost:3000"

# Telephony provider to simulate. The two adapters emit different native
# webhook shapes (form-encoded for Twilio, JSON envelope for Telnyx) and post
# to their own /api/webhooks/{name} endpoint. Both flow through the same
# state machine internally — only the boundary is provider-specific.
CALL_PROVIDER="twilio"
